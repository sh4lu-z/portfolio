{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    {
      "src": "api/*.go",
      "use": "@vercel/go"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/auth/(.*)",
      "dest": "/api/auth.go"
    },
    {
      "src": "/api/items/(.*)",
      "dest": "/api/routes.go"
    },
    {
      "src": "/api/items",
      "dest": "/api/routes.go"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/$1"
    }
  ]
}
